#!/usr/bin/env bash
set -euo pipefail

state_dir="/var/lib/hypr-login-manager"

if [ "$(id -u)" -ne 0 ]; then
  exec sudo -n "$0" "$@"
fi

for command in greetd systemctl start-hyprland; do
  if ! command -v "$command" >/dev/null 2>&1; then
    printf 'missing required command: %s\n' "$command" >&2
    exit 1
  fi
done

if [ ! -f /etc/greetd/config.toml ]; then
  printf 'missing /etc/greetd/config.toml\n' >&2
  exit 1
fi

if [ ! -f /usr/share/wayland-sessions/hyprland.desktop ]; then
  printf 'missing /usr/share/wayland-sessions/hyprland.desktop\n' >&2
  exit 1
fi

if grep -q '/usr/local/bin/hypr-greeter' /etc/greetd/config.toml; then
  for command in Hyprland gtkgreet swaybg; do
    if ! command -v "$command" >/dev/null 2>&1; then
      printf 'missing graphical greeter command: %s\n' "$command" >&2
      exit 1
    fi
  done

  for path in \
    /usr/local/bin/hypr-greeter \
    /etc/greetd/hyprland-greeter.conf \
    /etc/gtkgreet/asahi-liquid.css \
    /usr/local/share/asahi-hyprland/login-wallpaper.jpg; do
    if [ ! -e "$path" ]; then
      printf 'missing graphical greeter file: %s\n' "$path" >&2
      exit 1
    fi
  done

  runuser -u greetd -- Hyprland --verify-config --config /etc/greetd/hyprland-greeter.conf >/dev/null 2>&1
fi

install -d -m 755 "$state_dir"
install -d -o greetd -g greetd -m 755 /var/cache/tuigreet
date -Is > "$state_dir/greetd-pending"
rm -f "$state_dir/greetd-confirmed"

systemctl daemon-reload
systemctl disable --now hypr-login-manager-autorevert.timer >/dev/null 2>&1 || true
systemctl reset-failed hypr-login-manager-autorevert.service hypr-login-manager-autorevert.timer >/dev/null 2>&1 || true
systemctl enable hypr-login-manager-autorevert.timer >/dev/null
systemctl disable plasmalogin.service >/dev/null 2>&1 || true
systemctl enable --force greetd.service >/dev/null

if grep -q '/usr/local/bin/hypr-greeter' /etc/greetd/config.toml; then
  printf 'greetd + Hyprland/gtkgreet is enabled for the next boot.\n'
else
  printf 'greetd is enabled for the next boot.\n'
fi
printf 'Automatic rollback will run about 7 minutes after boot unless you run:\n'
printf '  sudo hypr-login-manager-confirm\n'
printf 'Manual rollback from a TTY:\n'
printf '  sudo hypr-login-manager-rollback\n'
