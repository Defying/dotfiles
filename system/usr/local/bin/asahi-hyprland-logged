#!/usr/bin/env bash
set -euo pipefail

home_dir="${HOME:-/home/ben}"
log_dir="$home_dir/hyprland-first-login"
ts="$(date +%Y%m%d-%H%M%S)"

private_runtime_dir() {
  if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
    printf '%s\n' "$XDG_RUNTIME_DIR"
    return 0
  fi
  local dir="${TMPDIR:-/tmp}/asahi-hyprland-$(id -u)"
  install -d -m 700 "$dir" 2>/dev/null || return 1
  printf '%s\n' "$dir"
}

if ! mkdir -p "$log_dir" 2>/dev/null; then
  log_dir="$(private_runtime_dir || printf '%s\n' "${home_dir}/.cache/asahi-hyprland")"
fi

log_file="$log_dir/session-$ts.log"

{
  printf 'Hyprland logged session\n'
  printf 'timestamp=%s\n' "$(date --iso-8601=seconds)"
  printf 'user=%s\n' "$(id -un)"
  printf 'home=%s\n' "$home_dir"
  printf 'wrapper=%s\n' "$0"
  printf 'command=/usr/bin/start-hyprland\n'
  printf 'config=%s\n' "$home_dir/.config/hypr/hyprland.conf"
  printf '\n'
} >> "$log_file" 2>&1

export XDG_CURRENT_DESKTOP=Hyprland
export XDG_SESSION_DESKTOP=Hyprland
export XDG_SESSION_TYPE=wayland

exec /usr/bin/start-hyprland >> "$log_file" 2>&1
