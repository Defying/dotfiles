#!/usr/bin/env python3
"""hypr-greeter-app — minimal greetd greeter for Hyprland. Username hardcoded to 'ben'."""

import gi
gi.require_version('Gtk', '3.0')
gi.require_version('Gio', '2.0')
from gi.repository import Gtk, Gdk, GLib, Gio

import json, os, socket, struct, sys, threading

GREETD_SOCK = os.environ.get('GREETD_SOCK', '/run/greetd.sock')
USERNAME    = 'ben'
START_CMD   = ['/usr/bin/start-hyprland']
START_ENV   = [
    'XDG_SESSION_TYPE=wayland',
    'XDG_CURRENT_DESKTOP=Hyprland',
    'XDG_SESSION_DESKTOP=Hyprland',
    'DESKTOP_SESSION=hyprland',
]

CSS = b"""
* {
  font-family: "SF Pro Text", "Inter", "Noto Sans", sans-serif;
  font-size: 17px;
  color: rgba(248, 250, 252, 0.96);
}
window, .background {
  background: transparent;
}
#card {
  min-width: 500px;
  padding: 42px 44px 38px;
  border-radius: 30px;
  border: 1px solid rgba(255, 255, 255, 0.42);
  background-color: rgba(10, 14, 24, 0.24);
  background-image: linear-gradient(145deg,
    rgba(255,255,255,0.30),
    rgba(255,255,255,0.09) 42%,
    rgba(51,204,255,0.14) 68%,
    rgba(192,132,245,0.18));
  box-shadow:
    0 30px 90px rgba(2, 6, 23, 0.48),
    inset 0 1px 0 rgba(255, 255, 255, 0.55),
    inset 0 -1px 0 rgba(255, 255, 255, 0.18);
}
#username-label {
  font-size: 26px;
  font-weight: bold;
  color: rgba(248, 250, 252, 0.96);
  text-shadow: 0 1px 4px rgba(2, 6, 23, 0.60);
  margin-bottom: 4px;
}
#hint-label {
  font-size: 14px;
  color: rgba(248, 250, 252, 0.50);
  margin-bottom: 18px;
}
#error-label {
  font-size: 14px;
  color: rgba(255, 120, 120, 0.92);
  margin-top: 6px;
}
entry {
  min-height: 46px;
  padding: 0 16px;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.32);
  background-color: rgba(6, 10, 18, 0.34);
  color: rgba(255, 255, 255, 0.96);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.18),
    0 10px 24px rgba(2, 6, 23, 0.22);
}
entry:focus {
  border-color: rgba(51, 204, 255, 0.88);
  background-color: rgba(9, 14, 25, 0.46);
  box-shadow:
