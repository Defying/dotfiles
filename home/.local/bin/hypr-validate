#!/usr/bin/env bash
set -uo pipefail

failures=0

check() {
  local name="$1"
  shift

  printf '%-42s' "$name"
  if "$@" >/tmp/hypr-validate.out 2>&1; then
    printf 'ok\n'
  else
    printf 'FAIL\n'
    sed 's/^/  /' /tmp/hypr-validate.out
    failures=$((failures + 1))
  fi
}

check "Hyprland config" Hyprland --verify-config -c /home/ben/.config/hypr/hyprland.conf
check "Fuzzel config" fuzzel --check-config --config /home/ben/.config/fuzzel/fuzzel.ini
check "Waybar JSON" jq empty /home/ben/.config/waybar/config.jsonc
check "helper scripts" bash -n /home/ben/.local/bin/hypr-power-menu /home/ben/.local/bin/hypr-screenshot /home/ben/.local/bin/hypr-clipboard-menu
check "Hyprland session file" test -f /usr/share/wayland-sessions/hyprland.desktop
check "Plasma fallback session file" test -f /usr/share/wayland-sessions/plasma.desktop
check "Plasma login manager active" systemctl is-active --quiet plasmalogin.service
check "Hyprland package installed" rpm -q hyprland
check "Plasma package still installed" rpm -q plasma-desktop
check "dotfiles repo clean" bash -lc 'test -z "$(git -C /home/ben/dotfiles status --porcelain)"'
check "dotfiles pushed" bash -lc 'local_head="$(git -C /home/ben/dotfiles rev-parse HEAD)"; remote_head="$(git -C /home/ben/dotfiles ls-remote origin refs/heads/main | cut -f1)"; test "$local_head" = "$remote_head"'
check "backup bundle present" test -d /home/ben/system-backups/pre-hyprland-20260522-083751

if sudo -n true >/dev/null 2>&1; then
  check "Btrfs root snapshot present" bash -lc 'sudo btrfs subvolume list -a / | rg -q "/.snapshots/pre-hyprland-20260522-083751/root$"'
  check "Btrfs home snapshot present" bash -lc 'sudo btrfs subvolume list -a / | rg -q "/.snapshots/pre-hyprland-20260522-083751/home$"'
else
  printf '%-42sSKIP (sudo unavailable)\n' "Btrfs snapshot checks"
fi

rm -f /tmp/hypr-validate.out

if [ "$failures" -ne 0 ]; then
  printf '\n%s check(s) failed.\n' "$failures" >&2
  exit 1
fi

printf '\nHyprland static validation passed. Real-session proof still requires logging into the Hyprland session.\n'
