#!/usr/bin/env bash
set -uo pipefail

failures=0
tmp="$(mktemp -t hypr-validate.XXXXXX)"
trap 'rm -f "$tmp"' EXIT

check() {
  local name="$1"
  shift

  printf '%-42s' "$name"
  if "$@" >"$tmp" 2>&1; then
    printf 'ok\n'
  else
    printf 'FAIL\n'
    sed 's/^/  /' "$tmp"
    failures=$((failures + 1))
  fi
}

check_match() {
  local name="$1"
  local repo_path="$2"
  local installed_path="$3"

  check "$name" cmp -s "/home/ben/dotfiles/$repo_path" "$installed_path"
}

check_link() {
  local name="$1"
  local live_path="$2"
  local repo_path="$3"

  check "$name" bash -lc "test -L '$live_path' && test \"\$(readlink -f '$live_path')\" = '/home/ben/dotfiles/$repo_path'"
}

check "Hyprland config" Hyprland --verify-config -c /home/ben/.config/hypr/hyprland.conf
check "Hyprland XDPH config" bash -lc 'test -f /home/ben/.config/hypr/xdph.conf && grep -q "custom_picker_binary = hyprland-share-picker" /home/ben/.config/hypr/xdph.conf'
check "Fuzzel config" fuzzel --check-config --config /home/ben/.config/fuzzel/fuzzel.ini
check "Waybar JSON" jq empty /home/ben/.config/waybar/config.jsonc
check "Ghostty terminal command" command -v ghostty
check "helper scripts" bash -n /home/ben/.local/bin/hypr-power-menu /home/ben/.local/bin/hypr-screenshot /home/ben/.local/bin/hypr-clipboard-menu /home/ben/.local/bin/hypr-rollback /home/ben/.local/bin/hypr-enable /home/ben/.local/bin/hypr-help /home/ben/.local/bin/hypr-doctor /home/ben/.local/bin/hypr-proof /home/ben/.local/bin/hypr-keybindings /home/ben/.local/bin/hypr-menu /home/ben/.local/bin/hypr-recovery-card /home/ben/.local/bin/hypr-logs /home/ben/.local/bin/hypr-login-status /home/ben/.local/bin/hypr-login-default /home/ben/.local/bin/hypr-refresh-session-env /home/ben/.local/bin/hypr-preflight /home/ben/.local/bin/hypr-smoke-test /home/ben/.local/bin/hypr-first-login-notice /home/ben/.local/bin/hypr-first-login-terminal /home/ben/.local/bin/hypr-session-autocheck /home/ben/dotfiles/scripts/install-hyprland-system-files.sh
check_link "Hyprland config linked" /home/ben/.config/hypr/hyprland.conf config/hypr/hyprland.conf
check_link "Hyprpaper config linked" /home/ben/.config/hypr/hyprpaper.conf config/hypr/hyprpaper.conf
check_link "Hypridle config linked" /home/ben/.config/hypr/hypridle.conf config/hypr/hypridle.conf
check_link "Hyprlock config linked" /home/ben/.config/hypr/hyprlock.conf config/hypr/hyprlock.conf
check_link "Hyprland XDPH config linked" /home/ben/.config/hypr/xdph.conf config/hypr/xdph.conf
check_link "Waybar config linked" /home/ben/.config/waybar/config.jsonc config/waybar/config.jsonc
check_link "Waybar style linked" /home/ben/.config/waybar/style.css config/waybar/style.css
check_link "Fuzzel config linked" /home/ben/.config/fuzzel/fuzzel.ini config/fuzzel/fuzzel.ini
check_link "Mako config linked" /home/ben/.config/mako/config config/mako/config
check_link "Swappy config linked" /home/ben/.config/swappy/config config/swappy/config
check_link "Hypr power menu linked" /home/ben/.local/bin/hypr-power-menu home/.local/bin/hypr-power-menu
check_link "Hypr screenshot linked" /home/ben/.local/bin/hypr-screenshot home/.local/bin/hypr-screenshot
check_link "Hypr clipboard menu linked" /home/ben/.local/bin/hypr-clipboard-menu home/.local/bin/hypr-clipboard-menu
check_link "Hypr rollback linked" /home/ben/.local/bin/hypr-rollback home/.local/bin/hypr-rollback
check_link "Hypr enable linked" /home/ben/.local/bin/hypr-enable home/.local/bin/hypr-enable
check_link "Hypr help linked" /home/ben/.local/bin/hypr-help home/.local/bin/hypr-help
check_link "Hypr doctor linked" /home/ben/.local/bin/hypr-doctor home/.local/bin/hypr-doctor
check_link "Hypr proof linked" /home/ben/.local/bin/hypr-proof home/.local/bin/hypr-proof
check_link "Hypr keybindings linked" /home/ben/.local/bin/hypr-keybindings home/.local/bin/hypr-keybindings
check_link "Hypr menu linked" /home/ben/.local/bin/hypr-menu home/.local/bin/hypr-menu
check_link "Hypr recovery card linked" /home/ben/.local/bin/hypr-recovery-card home/.local/bin/hypr-recovery-card
check_link "Hypr logs linked" /home/ben/.local/bin/hypr-logs home/.local/bin/hypr-logs
check_link "Hypr login status linked" /home/ben/.local/bin/hypr-login-status home/.local/bin/hypr-login-status
check_link "Hypr login default linked" /home/ben/.local/bin/hypr-login-default home/.local/bin/hypr-login-default
check_link "Hypr refresh session env linked" /home/ben/.local/bin/hypr-refresh-session-env home/.local/bin/hypr-refresh-session-env
check_link "Hypr preflight linked" /home/ben/.local/bin/hypr-preflight home/.local/bin/hypr-preflight
check_link "Hypr smoke test linked" /home/ben/.local/bin/hypr-smoke-test home/.local/bin/hypr-smoke-test
check_link "Hypr first-login notice linked" /home/ben/.local/bin/hypr-first-login-notice home/.local/bin/hypr-first-login-notice
check_link "Hypr first-login terminal linked" /home/ben/.local/bin/hypr-first-login-terminal home/.local/bin/hypr-first-login-terminal
check_link "Hypr session autocheck linked" /home/ben/.local/bin/hypr-session-autocheck home/.local/bin/hypr-session-autocheck
check "Hyprland session file" test -f /usr/share/wayland-sessions/hyprland.desktop
check "Hyprland logged session file" test -f /usr/share/wayland-sessions/hyprland-logged.desktop
check "Hyprland logged session desktop" desktop-file-validate /usr/share/wayland-sessions/hyprland-logged.desktop
check "Hyprland logged script" test -x /usr/local/bin/asahi-hyprland-logged
check_match "Hyprland logged session installed" system/usr/share/wayland-sessions/hyprland-logged.desktop /usr/share/wayland-sessions/hyprland-logged.desktop
check_match "Hyprland logged script installed" system/usr/local/bin/asahi-hyprland-logged /usr/local/bin/asahi-hyprland-logged
check "Hyprland safe config" Hyprland --verify-config -c /usr/local/share/asahi-hyprland/hyprland-safe.conf
check "Hyprland safe session file" test -f /usr/share/wayland-sessions/hyprland-safe.desktop
check "Hyprland safe session desktop" desktop-file-validate /usr/share/wayland-sessions/hyprland-safe.desktop
check "Hyprland safe script" test -x /usr/local/bin/asahi-hyprland-safe
check_match "Hyprland safe config installed" system/usr/local/share/asahi-hyprland/hyprland-safe.conf /usr/local/share/asahi-hyprland/hyprland-safe.conf
check_match "Hyprland safe session installed" system/usr/share/wayland-sessions/hyprland-safe.desktop /usr/share/wayland-sessions/hyprland-safe.desktop
check_match "Hyprland safe script installed" system/usr/local/bin/asahi-hyprland-safe /usr/local/bin/asahi-hyprland-safe
check "Plasma fallback session file" test -f /usr/share/wayland-sessions/plasma.desktop
check "Rollback Plasma session file" test -f /usr/share/wayland-sessions/plasma-rollback-hyprland.desktop
check "Rollback Plasma session desktop" desktop-file-validate /usr/share/wayland-sessions/plasma-rollback-hyprland.desktop
check "Rollback Plasma script" test -x /usr/local/bin/asahi-hyprland-rollback-plasma
check "Disable Hyprland script" test -x /usr/local/bin/asahi-hyprland-disable-config
check_match "Rollback Plasma session installed" system/usr/share/wayland-sessions/plasma-rollback-hyprland.desktop /usr/share/wayland-sessions/plasma-rollback-hyprland.desktop
check_match "Rollback Plasma script installed" system/usr/local/bin/asahi-hyprland-rollback-plasma /usr/local/bin/asahi-hyprland-rollback-plasma
check_match "Disable Hyprland script installed" system/usr/local/bin/asahi-hyprland-disable-config /usr/local/bin/asahi-hyprland-disable-config
check "Hyprland system installer check" /home/ben/dotfiles/scripts/install-hyprland-system-files.sh --check
check "Disable Hyprland dry-run" /usr/local/bin/asahi-hyprland-disable-config --check
check "Enable Hyprland command" test -x /home/ben/.local/bin/hypr-enable
check "Hyprland doctor command" test -x /home/ben/.local/bin/hypr-doctor
check "Hyprland proof command" test -x /home/ben/.local/bin/hypr-proof
check "Hyprland keybindings command" test -x /home/ben/.local/bin/hypr-keybindings
check "Hyprland menu command" test -x /home/ben/.local/bin/hypr-menu
check "Hyprland recovery card command" test -x /home/ben/.local/bin/hypr-recovery-card
check "Hyprland logs command" test -x /home/ben/.local/bin/hypr-logs
check "Hyprland login status command" test -x /home/ben/.local/bin/hypr-login-status
check "Hyprland login default command" test -x /home/ben/.local/bin/hypr-login-default
check "Hyprland refresh session env command" test -x /home/ben/.local/bin/hypr-refresh-session-env
check "Hyprland preflight command" test -x /home/ben/.local/bin/hypr-preflight
check "Hyprland smoke test command" test -x /home/ben/.local/bin/hypr-smoke-test
check "Hyprland first-login notice command" test -x /home/ben/.local/bin/hypr-first-login-notice
check "Hyprland first-login terminal command" test -x /home/ben/.local/bin/hypr-first-login-terminal
check "Plasma Login remembered session readable" bash -lc 'sudo -n test -r /var/lib/plasmalogin/.local/state/plasma-login-greeterstaterc'
check "Hyprland session autocheck command" test -x /home/ben/.local/bin/hypr-session-autocheck
check "notify-send command" test -x /usr/bin/notify-send
check "Hyprland portal preference" bash -lc 'grep -Eq "^default=hyprland(;|$)" /usr/share/xdg-desktop-portal/hyprland-portals.conf'
check "Hyprland portal descriptor" bash -lc 'grep -Eq "^UseIn=.*Hyprland" /usr/share/xdg-desktop-portal/portals/hyprland.portal'
check "Hyprland share picker" test -x /usr/bin/hyprland-share-picker
check "Plasma login manager active" systemctl is-active --quiet plasmalogin.service
check "Hyprland package installed" rpm -q hyprland
check "Plasma package still installed" rpm -q plasma-desktop
check "dotfiles repo clean" bash -lc 'test -z "$(git -C /home/ben/dotfiles status --porcelain)"'
check "dotfiles pushed" bash -lc 'local_head="$(git -C /home/ben/dotfiles rev-parse HEAD)"; remote_head="$(git -C /home/ben/dotfiles ls-remote origin refs/heads/main | cut -f1)"; test "$local_head" = "$remote_head"'
check "backup bundle present" test -d /home/ben/system-backups/pre-hyprland-20260522-083751
check "first-login backup bundle present" test -d /home/ben/system-backups/pre-first-hyprland-login-20260522-093108

if sudo -n true >/dev/null 2>&1; then
  check "Btrfs root snapshot present" bash -lc 'sudo btrfs subvolume list -a / | grep -Eq "/.snapshots/pre-hyprland-20260522-083751/root$"'
  check "Btrfs home snapshot present" bash -lc 'sudo btrfs subvolume list -a / | grep -Eq "/.snapshots/pre-hyprland-20260522-083751/home$"'
  check "First-login root snapshot present" bash -lc 'sudo btrfs subvolume list -a / | grep -Eq "/.snapshots/pre-first-hyprland-login-20260522-093108/root$"'
  check "First-login home snapshot present" bash -lc 'sudo btrfs subvolume list -a / | grep -Eq "/.snapshots/pre-first-hyprland-login-20260522-093108/home$"'
else
  printf '%-42sSKIP (sudo unavailable)\n' "Btrfs snapshot checks"
fi

if [ "$failures" -ne 0 ]; then
  printf '\n%s check(s) failed.\n' "$failures" >&2
  exit 1
fi

printf '\nHyprland static validation passed. Real-session proof still requires logging into the Hyprland session.\n'
