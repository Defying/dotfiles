#!/usr/bin/env bash
set -uo pipefail

failures=0
warnings=0
pending=0

state_file="/var/lib/plasmalogin/.local/state/plasma-login-greeterstaterc"
proof_marker="$HOME/.local/state/hyprland/real-login-proof"

section() {
  printf '\n== %s ==\n' "$1"
}

ok() {
  printf 'OK      %s\n' "$1"
}

warn() {
  printf 'WARN    %s\n' "$1"
  warnings=$((warnings + 1))
}

fail() {
  printf 'FAIL    %s\n' "$1"
  failures=$((failures + 1))
}

todo() {
  printf 'PENDING %s\n' "$1"
  pending=$((pending + 1))
}

latest_file() {
  local dir="$1"
  local pattern="$2"

  [ -d "$dir" ] || return 1
  find "$dir" -maxdepth 1 -type f -name "$pattern" -printf '%T@ %p\n' 2>/dev/null |
    sort -n |
    tail -n 1 |
    cut -d' ' -f2-
}

read_key() {
  local file="$1"
  local key="$2"

  if [ -r "$file" ]; then
    awk -F= -v key="$key" '$1 == key { value = $2 } END { if (value != "") print value }' "$file"
  elif sudo -n true >/dev/null 2>&1; then
    sudo awk -F= -v key="$key" '$1 == key { value = $2 } END { if (value != "") print value }' "$file" 2>/dev/null
  fi
}

session_property() {
  local property="$1"
  local session_id="${XDG_SESSION_ID:-}"

  [ -n "$session_id" ] || return 0
  loginctl show-session "$session_id" -p "$property" --value 2>/dev/null
}

printf 'Hyprland readiness audit\n'
printf 'host=%s user=%s date=%s\n' "$(hostname)" "$(id -un)" "$(date --iso-8601=seconds)"
printf 'read_only=true\n'

section "Current Session"
printf 'XDG_CURRENT_DESKTOP=%s\n' "${XDG_CURRENT_DESKTOP:-}"
printf 'XDG_SESSION_DESKTOP=%s\n' "${XDG_SESSION_DESKTOP:-}"
printf 'DESKTOP_SESSION=%s\n' "${DESKTOP_SESSION:-}"
printf 'WAYLAND_DISPLAY=%s\n' "${WAYLAND_DISPLAY:-}"
printf 'loginctl Desktop=%s\n' "$(session_property Desktop)"
printf 'loginctl Type=%s\n' "$(session_property Type)"
printf 'loginctl Service=%s\n' "$(session_property Service)"

current_session_is_hyprland=0
case "${XDG_CURRENT_DESKTOP:-}:$(session_property Desktop)" in
  *KDE*|*plasma*|*Plasma*)
    ok "current session is Plasma/KDE"
    ;;
  *Hyprland*)
    ok "current session is Hyprland"
    current_session_is_hyprland=1
    ;;
  *)
    warn "current desktop is not recognized as Plasma or Hyprland"
    ;;
esac

if pgrep -a -u "$(id -u)" 'Hyprland|start-hyprland|asahi-hyprland|waybar|hyprpaper|hypridle|hyprpolkitagent|wl-paste|nm-applet|fuzzel' >/dev/null 2>&1; then
  if [ "$current_session_is_hyprland" -eq 1 ]; then
    ok "Hyprland runtime processes are running in the current Hyprland session"
  else
    warn "Hyprland-related test/runtime processes are currently running"
  fi
else
  ok "no Hyprland test/runtime processes are running"
fi

if [ "$current_session_is_hyprland" -eq 1 ]; then
  if systemctl --user is-active --quiet graphical-session.target &&
    systemctl --user is-active --quiet hyprland-session.target; then
    ok "Hyprland user session target is active"
  else
    warn "Hyprland user session target is not fully active"
  fi

  if systemctl --user is-active --quiet xdg-desktop-portal.service; then
    ok "xdg-desktop-portal user service is active"
  else
    warn "xdg-desktop-portal user service is not active"
  fi
fi

section "Login Safety"
remembered_session="$(read_key "$state_file" LastLoggedInSession)"
if [ "$remembered_session" = "plasma.desktop" ]; then
  ok "Plasma is the remembered greeter session"
else
  warn "remembered greeter session is ${remembered_session:-unknown}, not plasma.desktop"
fi

for path in \
  /usr/share/wayland-sessions/plasma.desktop \
  /usr/share/wayland-sessions/plasma-rollback-hyprland.desktop \
  /usr/share/wayland-sessions/hyprland-safe.desktop \
  /usr/share/wayland-sessions/hyprland-recovery.desktop \
  /usr/share/wayland-sessions/hyprland-logged.desktop; do
  if [ -f "$path" ]; then
    ok "session file present: $path"
  else
    fail "session file missing: $path"
  fi
done

section "Emergency Recovery"
if [ -x /usr/local/bin/hypr-emergency ]; then
  ok "emergency command present: /usr/local/bin/hypr-emergency"
else
  fail "emergency command missing: /usr/local/bin/hypr-emergency"
fi

if [ -r /usr/local/share/asahi-hyprland/RECOVERY.txt ]; then
  ok "emergency recovery card present: /usr/local/share/asahi-hyprland/RECOVERY.txt"
else
  fail "emergency recovery card missing: /usr/local/share/asahi-hyprland/RECOVERY.txt"
fi

section "Backups"
for path in \
  /home/ben/system-backups/pre-hyprland-20260522-083751 \
  /home/ben/system-backups/pre-first-hyprland-login-20260522-093108; do
  if [ -d "$path" ]; then
    ok "backup bundle present: $path"
  else
    fail "backup bundle missing: $path"
  fi
done

if sudo -n true >/dev/null 2>&1; then
  for pattern in \
    '/.snapshots/pre-hyprland-20260522-083751/root$' \
    '/.snapshots/pre-hyprland-20260522-083751/home$' \
    '/.snapshots/pre-first-hyprland-login-20260522-093108/root$' \
    '/.snapshots/pre-first-hyprland-login-20260522-093108/home$'; do
    if sudo btrfs subvolume list -a / | grep -Eq "$pattern"; then
      ok "Btrfs snapshot present: $pattern"
    else
      fail "Btrfs snapshot missing: $pattern"
    fi
  done
else
  warn "sudo unavailable; Btrfs snapshot presence not checked"
fi

section "Dotfiles"
if [ -d /home/ben/dotfiles/.git ]; then
  commit="$(git -C /home/ben/dotfiles rev-parse --short HEAD 2>/dev/null || printf unknown)"
  printf 'commit=%s\n' "$commit"
  if [ -z "$(git -C /home/ben/dotfiles status --porcelain)" ]; then
    ok "dotfiles worktree is clean"
  else
    fail "dotfiles worktree has uncommitted changes"
  fi

  local_head="$(git -C /home/ben/dotfiles rev-parse HEAD 2>/dev/null || true)"
  remote_head="$(git -C /home/ben/dotfiles ls-remote origin refs/heads/main 2>/dev/null | cut -f1)"
  if [ -n "$local_head" ] && [ "$local_head" = "$remote_head" ]; then
    ok "dotfiles main is pushed"
  else
    fail "dotfiles main is not pushed"
  fi
else
  fail "dotfiles repo missing"
fi

section "Configured Hyprland"
if /home/ben/.local/bin/hypr-validate >/tmp/hypr-readiness-validate.log 2>&1; then
  ok "hypr-validate passes"
else
  fail "hypr-validate failed; see /tmp/hypr-readiness-validate.log"
fi

section "Nested Smoke Test"
smoke_report="$(latest_file "$HOME/hyprland-first-login" 'nested-smoke-*.report' || true)"
if [ -n "$smoke_report" ]; then
  printf 'latest_smoke_report=%s\n' "$smoke_report"
  if grep -q 'Hyprland nested smoke test passed' "$smoke_report"; then
    ok "latest nested smoke test passed"
  else
    warn "latest nested smoke test did not record success"
  fi

  if [ -d /home/ben/dotfiles/.git ]; then
    commit_ts="$(git -C /home/ben/dotfiles log -1 --format=%ct 2>/dev/null || true)"
    smoke_ts="$(stat -c '%Y' "$smoke_report" 2>/dev/null || true)"
    if [ -n "$commit_ts" ] && [ -n "$smoke_ts" ] && [ "$smoke_ts" -lt "$commit_ts" ]; then
      if [ -f "$proof_marker" ]; then
        ok "real login proof supersedes stale nested smoke proof"
      else
        warn "latest nested smoke test predates current dotfiles commit"
      fi
    fi
  fi
else
  todo "no nested smoke-test report found; optional: hypr-smoke-test --run"
fi

section "Real Login Proof"
if [ -f "$proof_marker" ]; then
  ok "real login proof marker exists"
  sed 's/^/  /' "$proof_marker"
  proof_commit="$(awk -F= '$1 == "dotfiles_commit" { print $2; exit }' "$proof_marker")"
  if [ -n "${commit:-}" ] && [ -n "$proof_commit" ]; then
    if [ "$proof_commit" = "$commit" ]; then
      ok "real login proof matches current dotfiles commit"
    else
      warn "real login proof was recorded for dotfiles commit $proof_commit, not current commit $commit"
    fi
  fi
else
  todo "real login proof marker missing: $proof_marker"
  printf '        This requires a normal Hyprland session from the login screen.\n'
fi

section "Summary"
printf 'failures=%s warnings=%s pending=%s\n' "$failures" "$warnings" "$pending"
if [ "$failures" -ne 0 ]; then
  printf 'Hyprland readiness has blocking failures.\n'
  exit 1
fi

if [ "$warnings" -ne 0 ] || [ "$pending" -ne 0 ]; then
  printf '\nNext actions:\n'
  if [ "$warnings" -ne 0 ]; then
    printf '  - Review warnings above. If the only warning is stale nested smoke proof, refresh it only when explicitly ready with: hypr-smoke-test --run\n'
  fi
  if [ "$pending" -ne 0 ]; then
    printf '  - Real proof requires choosing the normal Hyprland session manually at the login screen, then running: hypr-proof\n'
  fi
  printf '  - Emergency recovery card: hypr-emergency\n'
fi

if [ "$pending" -ne 0 ]; then
  printf 'Hyprland is prepared but not fully proven. Pending items remain.\n'
else
  printf 'Hyprland readiness is fully proven by current checks.\n'
fi
