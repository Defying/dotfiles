#!/usr/bin/env bash
set -uo pipefail

repo="/home/ben/dotfiles"
pre_backup="/home/ben/system-backups/pre-hyprland-20260522-083751"
first_login_backup="/home/ben/system-backups/pre-first-hyprland-login-20260522-093108"

status_line() {
  local label="$1"
  local path="$2"

  if [ -e "$path" ]; then
    printf 'ok      %s: %s\n' "$label" "$path"
  else
    printf 'missing %s: %s\n' "$label" "$path"
  fi
}

snapshot_line() {
  local label="$1"
  local pattern="$2"

  if sudo -n true >/dev/null 2>&1; then
    if sudo btrfs subvolume list -a / | grep -Eq "$pattern"; then
      printf 'ok      %s\n' "$label"
    else
      printf 'missing %s\n' "$label"
    fi
  else
    printf 'unknown %s (sudo unavailable)\n' "$label"
  fi
}

printf 'Hyprland recovery card\n'
printf 'host=%s user=%s date=%s\n' "$(hostname)" "$(id -un)" "$(date --iso-8601=seconds)"
if [ -d "$repo/.git" ]; then
  printf 'dotfiles=%s\n' "$repo"
  printf 'commit=%s\n' "$(git -C "$repo" rev-parse --short HEAD 2>/dev/null || printf unknown)"
fi

cat <<'EOF'

Login-screen choices:
  Plasma                       normal KDE fallback
  Plasma (Rollback Hyprland)   disables ~/.config/hypr, then starts KDE
  Hyprland (Safe)              minimal Hyprland, no user autostart
  Hyprland (Recovery Terminal) minimal Hyprland, auto-opens Ghostty card
  Hyprland (Logged)            normal Hyprland plus startup log
  Hyprland                     normal configured Hyprland

First test order:
  1. From Plasma, run: hypr-login-status
  2. Use Leave -> Log Out, not Lock or Switch User.
  3. Try Hyprland (Recovery Terminal) if you want the least scary test.
  4. Ghostty should open automatically with this card.
  5. Exit with Ctrl + Alt + Q or Cmd + Shift + Q.
  6. Try Hyprland.
  7. Ghostty should open automatically; otherwise press Ctrl + Alt + T.
  8. In Ghostty, run: hypr-doctor
  9. Run: hypr-proof
  10. If normal Hyprland fails before a terminal, try Hyprland (Logged).
  11. If Hyprland is broken, choose Plasma or Plasma (Rollback Hyprland).

Automation boundary:
  These helpers do not log out, restart Plasma Login Manager, or enable
  autologin. A real login-screen proof requires ben at the keyboard unless a
  separate passwordless recovery path has been deliberately set up first.

Hyprland keys:
  Cmd + Return        terminal
  Ctrl + Alt + T      terminal fallback
  Ctrl + Alt + Return terminal fallback
  Alt + Return        terminal fallback
  F12                 terminal fallback
  Cmd + Space         app launcher
  Cmd + Alt + Space   menu
  Ctrl + Alt + Space  menu fallback
  Cmd + K             keybindings
  Ctrl + Alt + K      keybindings fallback
  Cmd + Shift + /     doctor
  Cmd + Shift + Q     exit Hyprland
  Ctrl + Alt + Q      exit fallback
  Ctrl + Alt + Backspace exit fallback
  Cmd + Escape        power menu

Recovery commands:
  hypr-validate
  hypr-preflight
  hypr-readiness
  hypr-smoke-test --run
  hypr-login-status
  hypr-login-default plasma
  hypr-refresh-session-env
  hypr-logs
  hypr-doctor
  hypr-proof
  hypr-rollback --check
  hypr-rollback
  hypr-enable
  cd ~/dotfiles && scripts/install-hyprland-system-files.sh --check

TTY fallback:
  Ctrl + Alt + F3
  log in as ben
  hypr-rollback --check
  hypr-rollback
  sudo reboot
  choose Plasma at login

Logs:
  ~/hyprland-first-login/session-*.log
  ~/hyprland-first-login/recovery-session-*.log
  ~/hyprland-first-login/nested-smoke-*.report
  ~/hyprland-first-login/autocheck-*.log
  ~/hyprland-first-login/proof-*.log
  ~/hyprland-first-login/doctor-*.log
  ~/hyprland-rollback/rollback-*.log
  ~/.local/state/hyprland/real-login-proof

Backup anchors:
EOF

status_line "pre-Hyprland bundle" "$pre_backup"
status_line "pre-first-login bundle" "$first_login_backup"

printf '        /.snapshots/pre-hyprland-20260522-083751/root\n'
printf '        /.snapshots/pre-hyprland-20260522-083751/home\n'
printf '        /.snapshots/pre-first-hyprland-login-20260522-093108/root\n'
printf '        /.snapshots/pre-first-hyprland-login-20260522-093108/home\n'

printf '\nSnapshot presence:\n'
snapshot_line "pre-Hyprland root snapshot" '/.snapshots/pre-hyprland-20260522-083751/root$'
snapshot_line "pre-Hyprland home snapshot" '/.snapshots/pre-hyprland-20260522-083751/home$'
snapshot_line "pre-first-login root snapshot" '/.snapshots/pre-first-hyprland-login-20260522-093108/root$'
snapshot_line "pre-first-login home snapshot" '/.snapshots/pre-first-hyprland-login-20260522-093108/home$'

cat <<'EOF'

Full Btrfs snapshot rollback should be deliberate. Use Plasma/session rollback
first unless you are intentionally reverting the whole system state.
EOF
