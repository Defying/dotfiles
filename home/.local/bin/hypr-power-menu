#!/usr/bin/env bash
set -euo pipefail

choice="$(
  printf '%s\n' \
    "Lock" \
    "Logout Hyprland" \
    "Reboot" \
    "Power Off" |
    fuzzel --dmenu --prompt "power> "
)"

case "$choice" in
  "Lock")
    hyprlock
    ;;
  "Logout Hyprland")
    hyprctl dispatch exit
    ;;
  "Reboot")
    systemctl reboot
    ;;
  "Power Off")
    systemctl poweroff
    ;;
esac
