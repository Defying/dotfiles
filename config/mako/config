anchor=top-right
layer=overlay
sort=-time
font=SF Pro Text 10
background-color=#080b14bd
text-color=#f4f7fbff
border-color=#ffffff4d
progress-color=over #7dd3fc99
border-size=1
border-radius=14
default-timeout=4500
width=300
height=66
outer-margin=6,12,0,0
margin=6
padding=8,10
icons=1
icon-location=left
max-icon-size=28
icon-border-radius=8
markup=1
format=<b>%s</b>\n%b
on-button-left=dismiss
on-button-middle=invoke-default-action
on-touch=dismiss
max-visible=4
group-by=app-name,summary,body

[urgency=critical]
default-timeout=0
background-color=#260811c9
border-color=#ff6b6baa
progress-color=over #ff6b6b99

[app-name="disk-space"]
width=330
group-by=app-name,summary

[app-name="disk-space" urgency=critical]
default-timeout=0
ignore-timeout=1

[app-name="system-health"]
width=340
group-by=app-name,summary

[app-name="system-health" urgency=critical]
default-timeout=0
ignore-timeout=1

[app-name="battery"]
group-by=app-name,summary

[mode=do-not-disturb]
invisible=1

[app-name="AI usage"]
default-timeout=10000
group-by=app-name,summary

# Urgent AI-usage alerts stay until dismissed, but keep the same frosted
# notification surface so usage limits do not become a giant red block.
[app-name="AI usage" urgency=critical]
default-timeout=0
ignore-timeout=1
background-color=#080b14c9
border-color=#ffffff52
text-color=#f4f7fbff

[app-name=volume-osd]
anchor=top-center
layer=overlay
default-timeout=1400
ignore-timeout=1
width=280
height=58
border-radius=16
padding=8,12
outer-margin=6,0,0,0
format=<b>%s</b>  %b
group-by=app-name,category
background-color=#080b14bd
border-color=#ffffff4d
progress-color=over #7dd3fccc
