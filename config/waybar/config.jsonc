{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "height": 44,
  "spacing": 0,
  "tooltip-delay": 100,
  "modules-left": ["hyprland/workspaces", "custom/codex-tokens", "custom/claude-tokens"],
  "modules-center": ["custom/date", "custom/clock-24", "custom/weather"],
  "modules-right": ["tray", "custom/sysmon", "group/status", "custom/notifications", "custom/quick-settings"],

  "group/status": {
    "orientation": "inherit",
    "modules": ["network", "bluetooth", "pulseaudio", "battery"]
  },

  "custom/launcher": {
    "format": "⌘",
    "tooltip": "launcher: cmd + space",
    "on-click": "fuzzel --show drun"
  },

  "custom/quick-settings": {
    "format": "",
    "tooltip": "quick settings",
    "on-click": "/home/ben/dotfiles/scripts/waybar-quick-settings.sh"
  },

  "custom/notifications": {
    "exec": "/home/ben/dotfiles/scripts/waybar-notifications-count.sh",
    "return-type": "json",
    "interval": 5,
    "signal": 10,
    "format": "{}",
    "tooltip": "notifications",
    "on-click": "/home/ben/dotfiles/scripts/waybar-notifications.sh"
  },

  "custom/codex-tokens": {
    "exec": "/home/ben/dotfiles/scripts/waybar-openai-tokens.py",
    "return-type": "json",
    "interval": 30,
    "signal": 8,
    "format": "{}",
    "on-click": "/home/ben/dotfiles/scripts/ai-usage-popup.py codex",
    "on-click-middle": "/home/ben/dotfiles/scripts/waybar-ai-refresh.sh codex 8",
    "on-click-right": "/home/ben/dotfiles/scripts/waybar-quick-settings.sh"
  },

  "custom/claude-tokens": {
    "exec": "/home/ben/dotfiles/scripts/waybar-claude-usage.py",
    "return-type": "json",
    "interval": 60,
    "signal": 9,
    "format": "{}",
    "on-click": "/home/ben/dotfiles/scripts/ai-usage-popup.py claude",
    "on-click-middle": "/home/ben/dotfiles/scripts/waybar-ai-refresh.sh claude 9",
    "on-click-right": "/home/ben/dotfiles/scripts/waybar-quick-settings.sh"
  },

  "hyprland/workspaces": {
    "format": "{}",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "custom/date": {
    "exec": "/home/ben/.local/bin/waybar-helper date",
    "return-type": "json",
    "interval": 300,
    "format": "{}",
    "on-click": "korganizer"
  },

  "custom/clock-24": {
    "exec": "/home/ben/.local/bin/waybar-helper clock24",
    "return-type": "json",
    "interval": 30,
    "format": "{}",
    "on-click": "korganizer"
  },

  "custom/clock-12": {
    "exec": "/home/ben/dotfiles/scripts/waybar-clock-12.sh",
    "return-type": "json",
    "interval": 30,
    "format": "{}",
    "on-click": "korganizer"
  },

  "network": {
    "format-wifi": "{icon}",
    "format-ethernet": "",
    "format-disconnected": "",
    "format-icons": ["", "", ""],
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "ethernet",
    "tooltip-format-disconnected": "disconnected",
    "on-click": "/home/ben/dotfiles/scripts/network-popup.py",
    "on-click-right": "nm-connection-editor",
    "interval": 3
  },

  "bluetooth": {
    "format-on": "",
    "format-connected": "",
    "format-off": "",
    "format-disabled": "",
    "tooltip-format": "{controller_alias}\n{status}",
    "tooltip-format-connected": "{controller_alias}\n{num_connections} connected",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "tooltip-format-enumerate-connected-battery": "{device_alias} · {device_battery_percentage}%",
    "on-click": "/home/ben/dotfiles/scripts/audio-menu.sh"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-bluetooth": "󰋋",
    "format-bluetooth-muted": "󰋋",
    "format-muted": "",
    "format-icons": ["", "", ""],
    "scroll-step": 5,
    "max-volume": 100,
    "on-click": "/home/ben/dotfiles/scripts/audio-menu.sh",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "tooltip-format": "{desc}  ·  click for devices · middle-click mutes"
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-time": "{H}h {M}m",
    "tooltip-format": "battery {capacity}%\n{time}\n{power} W\nhealth {health}%\ncycles {cycles}",
    "format-icons": ["", "", "", "", ""],
    "states": {
      "critical": 10
    }
  },

  "tray": {
    "icon-size": 12,
    "spacing": 6
  },

  "custom/weather": {
    "exec": "/home/ben/dotfiles/scripts/waybar-weather.sh",
    "return-type": "json",
    "interval": 1800,
    "format": "{}",
    "on-click": "/home/ben/dotfiles/scripts/weather-popup.py"
  },

  "custom/sysmon": {
    "exec": "/home/ben/.local/bin/waybar-helper sysmon",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "on-click": "ghostty -e btop"
  }
}
